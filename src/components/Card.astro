---
interface Props {
	title: string;
	body: string;
	href: string;
	imageSrc: string;
}

const { href, title, body, imageSrc } = Astro.props;
---

	<div class="link-card">
		<a href={href}>
			<img src={imageSrc} alt={title} class="card-image"/>
			<h2>
				{title}
				<span>&rarr;</span>
			</h2>
			<p>
				{body}
			</p>
			
		</a>
	</div>


<style>
	body {
		background-color: #807A79;
	}
	

	.link-card {
		list-style: none;
		display: flex;
		flex-direction: column;
		background-color: #FF6F00;
		border-radius: 7px;
		overflow: hidden;
		margin: 30px;
		margin-top: 100px;
		width: 400px;
		height: 350px;
		border-radius: 10px;
	}

	.link-card > a {
		width: 100%;
		text-decoration: none;
		line-height: 1.4;
		padding: calc(1.5rem - 1px);
		border-radius: 8px;
		color: white;
		
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.card-image {
		width: auto;
		height: 200px;
		padding: 10px;
		object-fit: cover;
		border-radius: 7px 7px 0 0;
		
	}

	h2 {
		margin: 0;
		font-size: 1.25rem;
		transition: color 0.6s cubic-bezier(0.22, 1, 0.36, 1);
		text-align: center;
	}

	p {
		margin-top: 0.5rem;
		margin-bottom: 0;
		text-align: center;
	}

	.link-card:is(:hover, :focus-within) {
		background-image: var(--accent-gradient);
	}

	.link-card:is(:hover, :focus-within) h2 {
		color: rgb(var(--accent-light));
	}
</style>